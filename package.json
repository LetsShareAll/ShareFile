{
  "name": "share-file",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm exec esbuild assets/scripts/index.ts --bundle --outfile=assets/dist/index.js --sourcemap --watch",
    "check": "pnpm exec tsc --noEmit",
    "lint": "pnpm exec eslint assets/scripts/**/*.ts",
    "format": "pnpm exec prettier --write \"**/*.{ts,js,json,css,html}\" && pnpm exec eslint --fix assets/scripts/**/*.ts",
    "generate-info": "pnpm exec tsx assets/scripts/generate-info.ts --sync",
    "generate-share-file": "pnpm exec tsx assets/scripts/generate-share-file.ts",
    "generate": "pnpm run generate-info && pnpm run generate-share-file",
    "prebuild": "pnpm run generate && pnpm run check && pnpm run format && pnpm run lint",
    "build": "pnpm run prebuild && pnpm exec esbuild assets/scripts/index.ts --bundle --outfile=assets/dist/index.js --minify"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}

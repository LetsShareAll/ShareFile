{
  "name": "@share-file/cli",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write .",
    "generate-info": "tsx src/generate-info.ts ../../../public --sync",
    "generate-share-file": "tsx src/generate-share-file.ts ../../../public ../../../public/assets/data/share-file.json --cdn-url https://cdn-file.lssa.fun/github.com/LetsShareAll/ShareFile/blob/file/public",
    "generate": "pnpm run generate-info && pnpm run generate-share-file",
    "build:sea": "node scripts/build-sea.mjs"
  },
  "dependencies": {
    "@share-file/types": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
